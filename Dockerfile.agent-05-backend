# Dockerfile for CC Back-End Dev
FROM node:20

ENV DEBIAN_FRONTEND=noninteractive

RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

COPY agents/cc-backend/ ./agents/cc-backend/
COPY shared/ ./shared/
COPY package*.json ./

RUN npm install --production

CMD ["node", "agents/cc-backend/index.js"]
