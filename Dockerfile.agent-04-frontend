# Dockerfile for CC Front-End Dev
FROM node:20

ENV DEBIAN_FRONTEND=noninteractive

RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

COPY agents/cc-frontend/ ./agents/cc-frontend/
COPY shared/ ./shared/
COPY package*.json ./

RUN npm install --production

CMD ["node", "agents/cc-frontend/index.js"]
