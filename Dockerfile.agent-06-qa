# Use Node.js 20 as base for Claude Code agents
FROM node:20

ENV DEBIAN_FRONTEND=noninteractive

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

COPY agents/cc-monitor/ ./agents/cc-monitor/
COPY shared/ ./shared/
COPY package*.json ./

RUN npm install --production

CMD ["node", "agents/cc-monitor/index.js"]
