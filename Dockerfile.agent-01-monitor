# Use Node.js 20 as base
FROM node:20

ENV DEBIAN_FRONTEND=noninteractive

# Install OpenCLAW CLI
RUN npm install -g openclaw-cli

# Create app directory
WORKDIR /app

# Copy agent-specific skills and shared utilities
COPY agents/oc-monitor/ ./agents/oc-monitor/
COPY shared/ ./shared/
COPY package*.json ./

# Install dependencies (if any)
RUN npm install --production

# Entry point (Placeholder for actual supervisor script)
CMD ["node", "agents/oc-monitor/index.js"]
